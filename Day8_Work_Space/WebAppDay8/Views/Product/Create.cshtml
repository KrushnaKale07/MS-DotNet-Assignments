@model Product

<h2> New Product</h2>

@using (Html.BeginForm("Create", "Product", FormMethod.Post))
{
    <div class="mb-3">
        @Html.LabelFor(m=>m.Id, "Product Id", new{@class = "form-lable"})
        @Html.TextBoxFor(m=>m.Id,new{@class = "form-control"})
        @Html.ValidationMessageFor(m => m.Id, "", new { @class = "form-lable" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.Name, "Product Name", new { @class = "form-lable" })
        @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "form-lable" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.Price, "Product Price", new { @class = "form-lable" })
        @Html.TextBoxFor(m => m.Price, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Price, "", new { @class = "form-lable" })
    </div>

    <div class="mb-3">
        @Html.LabelFor(m => m.Description, "Product Description", new { @class = "form-lable" })
        @Html.TextBoxFor(m => m.Description, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Description, "", new { @class = "form-lable" })
    </div>

    <button type="submit" class="btn btn-success">Save</button>

    @Html.ActionLink("Back to list", "Index", null, new{@class = "btn btn-dark"})
}

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label for="Id" class="form-label"></label>
        <input type="number" id="Id" name="Id" class="form-control">
        <span asp-validation-for="Id" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label for="Name" class="form-label"></label>
        <input type="text" id="Name" name="Name" class="form-control">
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label for="Price" class="form-label"></label>
        <input type="text" id="Price" name="Price" class="form-control">
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label for="Description" class="form-label"></label>
        <input type="text" id="Description" name="Description" class="form-control">
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-dark">Baxk to list</a>
</form>

@section Scripts{
    <partial name="_ValidationScriptsPartial">
}