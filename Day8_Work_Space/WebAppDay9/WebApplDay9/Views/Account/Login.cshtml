@{
    @TempData["Success"]
    ;
}
<h2>Login Form</h2>
<form asp-action="Login" method="post">

    <input name="username" placeholder="Username" /><br />
    <input name="password" placeholder="Password" /><br />
    <button type="submit" class="btn btn-secondary">Login</button>
</form>
<span>@ViewBag.Error</span>