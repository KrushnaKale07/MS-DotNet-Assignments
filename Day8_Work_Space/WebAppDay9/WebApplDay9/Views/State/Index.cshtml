@model IEnumerable<WebApplDay9.Models.State>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.StateName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ContryId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Contry)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.StateName)
            </td>
            <td>
                @Html.DisplayFor(model => item.ContryId)
            </td>
            <td>
                @Html.DisplayFor(model => item.Contry)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.StateId">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.StateId">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.StateId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
